 {
  "doctype": "EasyEcom Field Mapping",
  "name": "EasyEcom-Supplier-Sync",
  "mapping_name": "EasyEcom-Supplier-Sync",
  "entity_type": "Supplier",
  "direction": "Bidirectional",
  "active": 1,
  "missing_field_policy": "Permissive",
  "version": 1,
  "last_modified_by": "Administrator",
  "last_modified_at": "2026-05-24 00:00:00",
  "change_reason": "Initial library fixture (\u00a75.11)",
  "rules": [
   {
    "erpnext_path": "name",
    "easyecom_path": "vendor_id",
    "transform_push": "identity",
    "transform_pull": "identity",
    "required": 1
   },
   {
    "erpnext_path": "supplier_name",
