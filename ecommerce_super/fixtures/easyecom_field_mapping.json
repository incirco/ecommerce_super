 {
  "doctype": "EasyEcom Field Mapping",
  "name": "EasyEcom-Channel-Pull",
  "mapping_name": "EasyEcom-Channel-Pull",
  "entity_type": "Channel",
  "direction": "Pull",
  "active": 1,
  "missing_field_policy": "Permissive",
  "version": 2,
  "last_modified_by": "Administrator",
  "last_modified_at": "2026-05-25 00:00:00",
  "change_reason": "\u00a78b refactor \u2014 reconciled to real /current-channel-status payload. Removed the channel_type rule (no such field in real payload \u2014 FDE-classified via the Marketplace Classification Workflow, gated on the Classify transition). Replaced the stale is_active rule (was bool_to_yn against assumed 'is_active' field) with a conditional_constant transform that maps real payload field 'status' (string 'Active'/'Inactive') to Check (1/0). The per-location sweep (flows/channel_discovery.py) calls this ruleset's pull() per element of data[] and then unions/dedupes by marketplace_id.",
  "rules": [
   {
    "erpnext_path": "marketplace_id",
    "easyecom_path": "marketplace_id",
    "transform_push": "identity",
    "transform_pull": "identity",
    "required": 1,
    "notes": "EE sends marketplace_id as Int (2, 60, 122). Marketplace.marketplace_id is Int (\u00a731.2.18). identity \u2014 no coercion needed."
   },
   {
    "erpnext_path": "marketplace_name",
    "easyecom_path": "marketplace_name",
    "transform_push": "identity",
    "transform_pull": "str_strip",
    "required": 1
   },
   {
    "erpnext_path": "is_active",
    "easyecom_path": "status",
    "transform_push": "identity",
    "transform_pull": "conditional_constant",
    "transform_args": {
     "conditions": [
      {
       "when": "source_payload.get('status') == 'Active'",
       "then": 1
      }
     ],
     "default": 0
    },
    "notes": "Real EE payload field is 'status' (string 'Active' / 'Inactive'). Marketplace.is_active is a Check (1/0). The conditional_constant transform expresses 'Active \u2192 1, else 0' AS A RULESET RULE \u2014 an FDE can adjust the condition (e.g. if EE renames the status field or adds new active-equivalent values) without a code deploy. This is the \u00a78.0 engine-as-API-insurance contract."
   }
  ]
 },
