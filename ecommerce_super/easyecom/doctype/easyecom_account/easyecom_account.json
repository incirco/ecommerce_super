   "label": "Pause Until",
   "description": "Manual pause — overrides the window."
  },
  {
   "fieldname": "window_exemptions",
   "fieldtype": "Table",
   "label": "Window Exemptions",
   "options": "EasyEcom Sync Window Exemption",
   "description": "Critical jobs that bypass the window — typically webhook-triggered."
  },
  {
