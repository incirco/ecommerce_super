  },
  {
   "fieldname": "item_master_mode_section",
   "fieldtype": "Section Break",
   "label": "Item Master Mode",
   "description": "Controls the §8d Item / Product master flow. Onboarding (default) is bidirectional and FDE-supervised; ERPNext-Mastered is the steady state where ERPNext owns the catalogue and EE-side changes show up as Drift flags rather than auto-overwriting. The flip is explicit and one-way (until manually reverted)."
  },
  {
   "fieldname": "item_master_mode",
   "fieldtype": "Select",
   "label": "Item Master Mode",
   "options": "onboarding\nerpnext_mastered",
   "default": "onboarding",
   "reqd": 1,
   "read_only": 1,
   "in_list_view": 1,
   "description": "§8.1.1. `onboarding` = bidirectional pull + push, supervised; `erpnext_mastered` = ERPNext is source of truth, pull becomes drift-detection only. Read-only on the form — the FDE flips via the Flip action below (with confirmation)."
  },
  {
   "fieldname": "item_master_flipped_at",
   "fieldtype": "Datetime",
   "label": "Flipped to ERPNext-Mastered At",
   "read_only": 1,
   "description": "Audit timestamp of when the FDE flipped to ERPNext-mastered. Empty during onboarding."
  },
  {
   "fieldname": "item_master_mode_col_2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "flip_to_erpnext_mastered_action",
   "fieldtype": "Button",
   "label": "Flip → ERPNext-Mastered",
   "description": "One-way flip: marks onboarding complete and switches the §8d pull from accept-and-create to drift-detection-only. The FDE confirms in a dialog before the flip lands. Reverse flips (back to onboarding) require manual intervention — design intent is one flip per client lifecycle."
  },
