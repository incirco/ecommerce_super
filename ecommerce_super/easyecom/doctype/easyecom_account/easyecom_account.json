 "fields": [
  {
   "fieldname": "account_name",
   "fieldtype": "Data",
   "label": "Account Name",
   "reqd": 1,
   "unique": 1,
   "description": "Human-readable label for this deployment's EasyEcom account."
  },
  {
   "fieldname": "enabled",
   "fieldtype": "Check",
   "label": "Enabled",
   "default": "1",
   "description": "Account-wide kill-switch. When unchecked, no syncs of any kind run for any location."
  },
  {
   "fieldname": "connection_status",
   "fieldtype": "Select",
   "label": "Connection Status",
   "options": "Disabled\nConnected\nDegraded\nDown",
   "default": "Disabled",
   "read_only": 1,
   "description": "Live indicator. Computed every 60s from connection health."
  },
  {
   "fieldname": "environment_badge",
   "fieldtype": "Select",
   "label": "Environment",
   "options": "Sandbox\nProduction",
   "default": "Sandbox",
   "reqd": 1
  },
  {
   "fieldname": "last_successful_sync_at",
   "fieldtype": "Datetime",
   "label": "Last Successful Sync At",
   "read_only": 1
  },
  {
   "fieldname": "setup_section",
   "fieldtype": "Section Break",
   "label": "Setup",
   "collapsible": 1
  },
  {
   "fieldname": "api_endpoint",
   "fieldtype": "Data",
   "label": "API Endpoint",
   "reqd": 1,
   "default": "https://api.easyecom.io",
   "description": "EasyEcom base URL. Production: https://api.easyecom.io. Sandbox URL differs."
  },
  {
   "fieldname": "x_api_key",
   "fieldtype": "Password",
   "label": "X-API-Key",
   "reqd": 1,
   "permlevel": 1,
   "description": "Account-level API key. Generated only from the client's Primary Seller Account; regenerating it invalidates the previous key instantly."
  },
  {
   "fieldname": "email",
   "fieldtype": "Password",
   "label": "Account Email",
   "reqd": 1,
   "permlevel": 1,
   "description": "EasyEcom account email (must be a user with multi-location access in the primary account). Treated as a credential (§3.7.1)."
  },
  {
   "fieldname": "password",
   "fieldtype": "Password",
   "label": "Account Password",
   "reqd": 1,
   "permlevel": 1
  },
  {
   "fieldname": "rate_limit_tier",
   "fieldtype": "Select",
   "label": "Rate Limit Tier",
   "options": "\nDefault\nBronze\nSilver\nGold\nDiamond",
   "reqd": 1,
   "description": "Tier EasyEcom has assigned to this api_key. No preset default — set to whatever EE has actually assigned. Drives throttle and daily quota (§3.10). A newly generated key sits in Default tier until EE upgrades it; \"tier still Default at go-live\" is a blocking onboarding condition."
  },
  {
   "fieldname": "default_location_key",
   "fieldtype": "Link",
   "label": "Default Location",
   "options": "EasyEcom Location",
   "description": "Used for location-agnostic operations (typically the primary location for master ops)."
  },
  {
   "fieldname": "test_connection_action",
   "fieldtype": "Button",
   "label": "Test Connection",
   "description": "Triggers a /access/token call against the default_location_key and reports result inline."
  },
  {
   "fieldname": "sync_window_section",
   "fieldtype": "Section Break",
   "label": "Sync Window",
   "collapsible": 1
  },
  {
   "fieldname": "sync_window_enabled",
   "fieldtype": "Check",
   "label": "Enable Sync Window",
   "default": "0",
   "description": "If unchecked, syncs run 24x7."
  },
  {
   "fieldname": "sync_window_start",
   "fieldtype": "Time",
   "label": "Daily Start",
   "default": "22:00:00"
  },
  {
   "fieldname": "sync_window_end",
   "fieldtype": "Time",
   "label": "Daily End",
   "default": "06:00:00",
   "description": "May cross midnight."
  },
  {
   "fieldname": "sync_window_weekends_only",
   "fieldtype": "Check",
   "label": "Weekends Only",
   "default": "0"
  },
  {
