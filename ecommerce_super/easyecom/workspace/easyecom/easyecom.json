screpancies</div><div style=\\\"font-size:11px;color:#9ca3af;margin-top:6px;line-height:1.4;\\\">pending \\u00a723; Integration Discrepancy DocType deliberately unbuilt</div></div>\", \"col\": 3}}, {\"id\": \"sp-pend\", \"type\": \"spacer\", \"data\": {\"col\": 12}}, {\"id\": \"h-ch\", \"type\": \"header\", \"data\": {\"text\": \"<div style=\\\"display:flex;align-items:center;gap:12px;margin:20px 0 12px 0;padding:10px 14px;background:linear-gradient(90deg,#14b8a615 0%,transparent 100%);border-left:4px solid #14b8a6;border-radius:6px;\\\"><span style=\\\"font-size:22px;line-height:1;\\\">\\ud83d\\udcc8</span><div><div style=\\\"font-size:15px;font-weight:700;color:#111827;line-height:1.2;\\\">Charts</div><div style=\\\"font-size:12px;color:#6b7280;margin-top:2px;\\\">recent activity and outcome distributions</div></div></div>\", \"col\": 12}}, {\"id\": \"ch-vol\", \"type\": \"chart\", \"data\": {\"chart_name\": \"EasyEcom API Call Volume (7d)\", \"col\": 6}}, {\"id\": \"ch-sr\", \"type\": \"chart\", \"data\": {\"chart_name\": \"Sync Record Status (Item-only currently)\", \"col\": 6}}, {\"id\": \"sp-ch\", \"type\": \"spacer\", \"data\": {\"col\": 12}}, {\"id\": \"h-nav\", \"type\": \"header\", \"data\": {\"text\": \"<div style=\\\"display:flex;align-items:center;gap:12px;margin:20px 0 12px 0;padding:10px 14px;background:linear-gradient(90deg,#6366f115 0%,transparent 100%);border-left:4px solid #6366f1;border-radius:6px;\\\"><span style=\\\"font-size:22px;line-height:1;\\\">\\ud83e\\uddf0</span><div><div style=\\\"font-size:15px;font-weight:700;color:#111827;line-height:1.2;\\\">Quick Navigation</div><div style=\\\"font-size:12px;color:#6b7280;margin-top:2px;\\\">jump to setup, masters, worklists, ops, logs</div></div></div>\", \"col\": 12}}, {\"id\": \"card-setup\", \"type\": \"card\", \"data\": {\"card_name\": \"Setup\", \"col\": 4}}, {\"id\": \"card-masters\", \"type\": \"card\", \"data\": {\"card_name\": \"Masters\", \"col\": 4}}, {\"id\": \"card-worklists\", \"typ