 "content": "[{\"id\": \"hero\", \"type\": \"header\", \"data\": {\"text\": \"<div style=\\\"background:linear-gradient(135deg,#4f46e5 0%,#7c3aed 100%);border-radius:12px;padding:24px 28px;margin:8px 0 20px 0;color:white;\\\"><div style=\\\"font-size:11px;text-transform:uppercase;letter-spacing:1.5px;opacity:0.85;font-weight:600;\\\">EasyEcom Integration</div><div style=\\\"font-size:24px;font-weight:700;margin-top:4px;line-height:1.2;\\\">Operations Dashboard</div><div style=\\\"font-size:13px;opacity:0.9;margin-top:6px;\\\">Setup &middot; Masters &middot; FDE worklists &middot; Runtime logs</div></div>\", \"col\": 12}}, {\"id\": \"h-op\", \"type\": \"header\", \"data\": {\"text\": \"<div style=\\\"display:flex;align-items:center;gap:12px;margin:20px 0 12px 0;padding:10px 14px;background:linear-gradient(90deg,#10b98115 0%,transparent 100%);border-left:4px solid #10b981;border-radius:6px;\\\"><span style=\\\"font-size:22px;line-height:1;\\\">\\u26a1</span><div><div style=\\\"font-size:15px;font-weight:700;color:#111827;line-height:1.2;\\\">Operational Status</div><div style=\\\"font-size:12px;color:#6b7280;margin-top:2px;\\\">environment \\u00b7 connection \\u00b7 account state</div></div></div>\", \"col\": 12}}, {\"id\": \"tstrip\", \"type\": \"custom_block\", \"data\": {\"custom_block_name\": \"EasyEcom Top Strip\", \"col\": 12}}, {\"id\": \"sp-op\", \"type\": \"spacer\", \"data\": {\"col\": 12}}, {\"id\": \"h-found\", \"type\": \"header\", \"data\": {\"text\": \"<div style=\\\"display:flex;align-items:center;gap:12px;margin:20px 0 12px 0;padding:10px 14px;background:linear-gradient(90deg,#3b82f615 0%,transparent 100%);border-left:4px solid #3b82f6;border-radius:6px;\\\"><span style=\\\"font-size:22px;line-height:1;\\\">\\ud83e\\udded</span><div><div style=\\\"font-size:15px;font-weight:700;color:#111827;line-height:1.2;\\\">Foundationals \\u2014 FDE Worklist</div><div style=\\\"font-size:12px;color:#6b7280;margin-top:2px;\\\">masters waiting to be mapped or configured</div></div></div>\", \"col\": 12}}, {\"id\": \"wl-loc\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"Locations - To Map\", \"col\": 4}}, {\"id\": \"wl-ch\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"Channels - Unclassified\", \"col\": 4}}, {\"id\": \"wl-tax\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"Tax Rules - To Configure\", \"col\": 4}}, {\"id\": \"sp-found\", \"type\": \"spacer\", \"data\": {\"col\": 12}}, {\"id\": \"h-items\", \"type\": \"header\", \"data\": {\"text\": \"<div style=\\\"display:flex;align-items:center;gap:12px;margin:20px 0 12px 0;padding:10px 14px;background:linear-gradient(90deg,#8b5cf615 0%,transparent 100%);border-left:4px solid #8b5cf6;border-radius:6px;\\\"><span style=\\\"font-size:22px;line-height:1;\\\">\\ud83d\\udce6</span><div><div style=\\\"font-size:15px;font-weight:700;color:#111827;line-height:1.2;\\\">Items \\u2014 Entity Sync</div><div style=\\\"font-size:12px;color:#6b7280;margin-top:2px;\\\">product master flagged states (post-pull / post-push)</div></div></div>\", \"col\": 12}}, {\"id\": \"wl-it-drift\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"Items in Drift\", \"col\": 4}}, {\"id\": \"wl-it-cflag\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"Items Created-Flagged\", \"col\": 4}}, {\"id\": \"wl-it-fnc\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"Items Flagged-Not-Created\", \"col\": 4}}, {\"id\": \"sp-items\", \"type\": \"spacer\", \"data\": {\"col\": 12}}, {\"id\": \"h-cust\", \"type\": \"header\", \"data\": {\"text\": \"<div style=\\\"display:flex;align-items:center;gap:12px;margin:20px 0 12px 0;padding:10px 14px;background:linear-gradient(90deg,#ec489915 0%,transparent 100%);border-left:4px solid #ec4899;border-radius:6px;\\\"><span style=\\\"font-size:22px;line-height:1;\\\">\\ud83e\\udd1d</span><div><div style=\\\"font-size:15px;font-weight:700;color:#111827;line-height:1.2;\\\">Customers \\u2014 Entity Sync</div><div style=\\\"font-size:12px;color:#6b7280;margin-top:2px;\\\">wholesale customer master flagged states</div></div></div>\", \"col\": 12}}, {\"id\": \"wl-cust-drift\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"Customers in Drift\", \"col\": 4}}, {\"id\": \"wl-cust-cflag\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"Customers Created-Flagged\", \"col\": 4}}, {\"id\": \"wl-cust-fnc\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"Customers Flagged-Not-Created\", \"col\": 4}}, {\"id\": \"sp-cust\", \"type\": \"spacer\", \"data\": {\"col\": 12}}, {\"id\": \"h-kpi\", \"type\": \"header\", \"data\": {\"text\": \"<div style=\\\"display:flex;align-items:center;gap:12px;margin:20px 0 12px 0;padding:10px 14px;background:linear-gradient(90deg,#f59e0b15 0%,transparent 100%);border-left:4px solid #f59e0b;border-radius:6px;\\\"><span style=\\\"font-size:22px;line-height:1;\\\">\\ud83d\\udcca</span><div><div style=\\\"font-size:15px;font-weight:700;color:#111827;line-height:1.2;\\\">KPI Tiles</div><div style=\\\"font-size:12px;color:#6b7280;margin-top:2px;\\\">live operational counts (last attempt + last hour)</div></div></div>\", \"col\": 12}}, {\"id\": \"kpi-sr\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"Open Sync Records (Failed)\", \"col\": 4}}, {\"id\": \"kpi-api\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"API Calls (last hour)\", \"col\": 4}}, {\"id\": \"kpi-qj\", \"type\": \"number_card\", \"data\": {\"number_card_name\": \"Queue Job Depth\", \"col\": 4}}, {\"id\": \"sp-kpi\", \"type\": \"spacer\", \"data\": {\"col\": 12}}, {\"id\": \"h-pend\", \"type\": \"header\", \"data\": {\"text\": \"<div style=\\\"display:flex;align-items:center;gap:12px;margin:20px 0 12px 0;padding:10px 14px;background:linear-gradient(90deg,#9ca3af15 0%,transparent 100%);border-left:4px solid #9ca3af;border-radius:6px;\\\"><span style=\\\"font-size:22px;line-height:1;\\\">\\u23f3</span>